{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI PR Review Toolkit",
  "version": "1.0.0",
  "identifier": "com.firstnode.ai-pr-review-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI PR Review Toolkit",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "FirstNode",
    "copyright": "© 2026 FirstNode",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {}
  }
}
